    <sys_security_acl action="INSERT_OR_UPDATE">
        <active>true</active>
        <admin_overrides>true</admin_overrides>
        <advanced>true</advanced>
        <applies_to/>
        <condition/>
        <controlled_by_refs/>
        <decision_type>allow</decision_type>
        <description>College READ: platform_admin full, college_admin own college, student verified colleges</description>
        <local_or_existing>Local</local_or_existing>
        <name>x_2097092_linq_college</name>
        <operation display_value="read">read</operation>
        <script><![CDATA[
    if (gs.hasRole('x_2097092_linq.platform_admin')) {
      answer = true;
    } else if (gs.hasRole('x_2097092_linq.college_admin')) {
      // College admin reads only their own college
      var userCollege = gs.getUser().getRecord().getValue('u_college');
      answer = (current.getUniqueValue() == userCollege);
    } else {
      // Students can read active/verified colleges
      answer = (current.getValue('active') == 'true');
    }
  ]]></script>
